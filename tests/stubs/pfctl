#!/bin/sh

set -eu

STATE_DIR=${PFCTL_STATE_DIR:?}
LOG_FILE=${PFCTL_LOG:?}
mkdir -p "$STATE_DIR"

printf '%s\n' "$*" >>"$LOG_FILE"

LIVE_HOOK_FILE=$STATE_DIR/live-hook

if [ "$#" -eq 1 ] && [ "$1" = "-sr" ]; then
  if [ "${PFCTL_HAS_HOOK:-0}" = "1" ] || [ -f "$LIVE_HOOK_FILE" ]; then
    printf 'anchor "orport-guard"\n'
  fi
  exit 0
fi

if [ "$#" -eq 2 ] && [ "$1" = "-nf" ]; then
  [ -f "$2" ] || exit 1
  exit 0
fi

if [ "$#" -eq 2 ] && [ "$1" = "-f" ]; then
  [ -f "$2" ] || exit 1
  if grep -F 'anchor "orport-guard"' "$2" >/dev/null 2>&1; then
    : >"$LIVE_HOOK_FILE"
  else
    rm -f "$LIVE_HOOK_FILE"
  fi
  exit 0
fi

if [ "$#" -ge 5 ] && [ "$1" = "-n" ] && [ "$2" = "-a" ] && [ "$4" = "-f" ]; then
  [ -f "$5" ] || exit 1
  exit 0
fi

if [ "$#" -ge 4 ] && [ "$1" = "-a" ] && [ "$3" = "-f" ]; then
  anchor=$2
  cp "$4" "$STATE_DIR/anchor-$(printf '%s' "$anchor" | tr '/' '_').conf"
  exit 0
fi

if [ "$#" -ge 3 ] && [ "$1" = "-a" ] && [ "$3" = "-sr" ]; then
  anchor=$2
  file="$STATE_DIR/anchor-$(printf '%s' "$anchor" | tr '/' '_').conf"
  [ -f "$file" ] && cat "$file"
  exit 0
fi

if [ "$#" -ge 4 ] && [ "$1" = "-a" ] && [ "$3" = "-vvs" ] && [ "$4" = "rules" ]; then
  anchor=$2
  if [ -n "${PFCTL_VVS_RULES_FIXTURE:-}" ] && [ -f "$PFCTL_VVS_RULES_FIXTURE" ]; then
    cat "$PFCTL_VVS_RULES_FIXTURE"
    exit 0
  fi
  file="$STATE_DIR/anchor-$(printf '%s' "$anchor" | tr '/' '_').conf"
  [ -f "$file" ] && cat "$file"
  exit 0
fi

if [ "$#" -ge 7 ] && [ "$1" = "-a" ] && [ "$3" = "-t" ] && [ "$5" = "-T" ] && [ "$6" = "replace" ] && [ "$7" = "-f" ]; then
  anchor=$2
  table=$4
  cp "$8" "$STATE_DIR/table-${anchor}-$table.txt"
  exit 0
fi

if [ "$#" -ge 6 ] && [ "$1" = "-a" ] && [ "$3" = "-t" ] && [ "$5" = "-T" ] && [ "$6" = "show" ]; then
  anchor=$2
  table=$4
  file="$STATE_DIR/table-${anchor}-$table.txt"
  [ -f "$file" ] && cat "$file"
  exit 0
fi

if [ "$#" -ge 7 ] && [ "$1" = "-a" ] && [ "$3" = "-t" ] && [ "$5" = "-T" ] && [ "$6" = "expire" ]; then
  [ "${PFCTL_FAIL_EXPIRE:-0}" = "1" ] && exit 1
  anchor=$2
  table=$4
  file="$STATE_DIR/table-${anchor}-$table.txt"
  [ -f "$file" ] || : >"$STATE_DIR/table-${anchor}-$table.txt"
  exit 0
fi

if [ "$#" -ge 6 ] && [ "$1" = "-a" ] && [ "$3" = "-t" ] && [ "$5" = "-T" ] && [ "$6" = "flush" ]; then
  anchor=$2
  table=$4
  : >"$STATE_DIR/table-${anchor}-$table.txt"
  exit 0
fi

if [ "$#" -ge 6 ] && [ "$1" = "-a" ] && [ "$3" = "-t" ] && [ "$5" = "-T" ] && [ "$6" = "kill" ]; then
  exit 0
fi

if [ "$#" -ge 5 ] && [ "$1" = "-t" ] && [ "$3" = "-T" ] && [ "$4" = "replace" ] && [ "$5" = "-f" ]; then
  table=$2
  cp "$6" "$STATE_DIR/table-$table.txt"
  exit 0
fi

if [ "$#" -ge 4 ] && [ "$1" = "-t" ] && [ "$3" = "-T" ] && [ "$4" = "show" ]; then
  table=$2
  file="$STATE_DIR/table-$table.txt"
  [ -f "$file" ] && cat "$file"
  exit 0
fi

if [ "$#" -ge 5 ] && [ "$1" = "-t" ] && [ "$3" = "-T" ] && [ "$4" = "expire" ]; then
  [ "${PFCTL_FAIL_EXPIRE:-0}" = "1" ] && exit 1
  table=$2
  file="$STATE_DIR/table-$table.txt"
  [ -f "$file" ] || : >"$STATE_DIR/table-$table.txt"
  exit 0
fi

if [ "$#" -ge 4 ] && [ "$1" = "-t" ] && [ "$3" = "-T" ] && [ "$4" = "flush" ]; then
  table=$2
  : >"$STATE_DIR/table-$table.txt"
  exit 0
fi

if [ "$#" -ge 4 ] && [ "$1" = "-t" ] && [ "$3" = "-T" ] && [ "$4" = "kill" ]; then
  exit 0
fi

if [ "$#" -eq 2 ] && [ "$1" = "-s" ] && [ "$2" = "state" ]; then
  exit 0
fi

printf 'unsupported pfctl invocation: %s\n' "$*" >&2
exit 1
