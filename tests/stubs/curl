#!/bin/sh

output_file=
url=
prev=
for arg in "$@"; do
  if [ "$prev" = "-o" ]; then
    output_file=$arg
    prev=
    continue
  fi
  case "$arg" in
    -o)
      prev=-o
      continue
      ;;
    *)
      url=$arg
      ;;
  esac
done

emit() {
  if [ -n "$output_file" ]; then
    cat >"$output_file"
  else
    cat
  fi
}

case "$url" in
  *"${CURL_FAIL_URL_SUBSTRING:-__never_match__}"*)
    exit 1
    ;;
  *orport-guard/releases/*/orport-guard)
    [ -n "${CURL_DOWNLOAD_FILE:-}" ] || exit 1
    emit <"$CURL_DOWNLOAD_FILE"
    ;;
  *authorities-v4.txt)
    emit <<'EOF'
header
header
header
128.31.0.39
171.25.193.9
EOF
    ;;
  *authorities-v6.txt)
    emit <<'EOF'
header
header
header
2001:67c:289c::9
2610:1c0:0:5::131
EOF
    ;;
  *snowflake.txt)
    emit <<'EOF'
header
header
header
141.212.118.18
EOF
    ;;
  *snowflake-v6.txt)
    emit <<'EOF'
header
header
header
2607:f018:600:8:be30:5bff:fef1:c6fa
EOF
    ;;
  *)
    exit 1
    ;;
esac
