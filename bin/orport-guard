#!/bin/sh

set -eu

PROGRAM_NAME=${0##*/}
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ROOT_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
PROGRAM_PATH=$SCRIPT_DIR/$PROGRAM_NAME

. "$ROOT_DIR/lib/pf.sh"

usage() {
  cat <<EOF
Usage: $PROGRAM_NAME [options] <command>

Commands:
  enable     Install the PF hook if needed, reload pf.conf, then apply the anchor.
  check      Render the anchor and run PF syntax checks without loading it.
  apply      Render and load the PF anchor, then refresh trust tables.
  refresh    Refresh trust tables only.
  expire     Expire block-table entries older than the configured threshold.
  render     Print the generated PF anchor to stdout.
  status     Show discovered targets and PF status for this tool.
  install-hook
             Ensure the root pf.conf contains anchor "orport-guard".
  install-cron
             Install managed cron entries for expiry and trust refresh.
  remove-cron
             Remove managed cron entries for this tool.
  disable    Disable only the tool-managed PF anchor and tables.

Options:
  -c, --config PATH           Use an alternate config file.
      --state-dir PATH        Override the state directory.
      --anchor NAME           Override the PF anchor name.
      --pf-conf PATH          Override the root PF config path.
      --profile NAME          Select a threshold profile (default or aggressive).
      --block-expire-seconds N
                              Expire block-table entries older than N seconds.
      --render-file PATH      Override the rendered anchor path.
      --torrc PATH            Add a torrc path for discovery.
      --target VALUE          Add an explicit target (IPv4:port or [IPv6]:port).
      --trust VALUE           Add an explicit trusted IP or network.
      --service VALUE         Add an exempt local service (IPv4:port or [IPv6]:port).
      --ipv4-only             Disable IPv6 rendering.
      --ipv6-only             Disable IPv4 rendering.
  -h, --help                  Show this help text.

Config precedence:
  CLI flags override the config file, which overrides discovery defaults.
EOF
}

CONFIG_FILE=
COMMAND=
CLI_STATE_DIR=
CLI_ANCHOR=
CLI_PF_CONF=
CLI_PROFILE=
CLI_BLOCK_EXPIRE_SECONDS=
CLI_RENDER_FILE=
CLI_TORRC_PATHS=
CLI_TARGETS=
CLI_TRUST=
CLI_SERVICES=
CLI_ENABLE_IPV4=
CLI_ENABLE_IPV6=

while [ $# -gt 0 ]; do
  case "$1" in
    enable|check|apply|refresh|expire|render|status|install-hook|install-cron|remove-cron|disable)
      COMMAND=$1
      shift
      break
      ;;
    -c|--config)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CONFIG_FILE=$2
      shift 2
      ;;
    --state-dir)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_STATE_DIR=$2
      shift 2
      ;;
    --anchor)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_ANCHOR=$2
      shift 2
      ;;
    --pf-conf)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_PF_CONF=$2
      shift 2
      ;;
    --profile)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_PROFILE=$2
      shift 2
      ;;
    --block-expire-seconds)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_BLOCK_EXPIRE_SECONDS=$2
      shift 2
      ;;
    --render-file)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_RENDER_FILE=$2
      shift 2
      ;;
    --torrc)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_TORRC_PATHS="$CLI_TORRC_PATHS $2"
      shift 2
      ;;
    --target)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_TARGETS="$CLI_TARGETS $2"
      shift 2
      ;;
    --trust)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_TRUST="$CLI_TRUST $2"
      shift 2
      ;;
    --service)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_SERVICES="$CLI_SERVICES $2"
      shift 2
      ;;
    --ipv4-only)
      CLI_ENABLE_IPV4=1
      CLI_ENABLE_IPV6=0
      shift
      ;;
    --ipv6-only)
      CLI_ENABLE_IPV4=0
      CLI_ENABLE_IPV6=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      tor_ddos_die "unknown argument: $1"
      ;;
  esac
done

[ -n "$COMMAND" ] || {
  usage >&2
  exit 2
}

tor_ddos_set_defaults "$ROOT_DIR"

if [ -n "$CONFIG_FILE" ]; then
  tor_ddos_load_config "$CONFIG_FILE"
else
  tor_ddos_load_config "$CONFIG_FILE_DEFAULT"
fi

[ -z "$CLI_STATE_DIR" ] || STATE_DIR=$CLI_STATE_DIR
[ -z "$CLI_ANCHOR" ] || PF_ANCHOR=$CLI_ANCHOR
[ -z "$CLI_PF_CONF" ] || PF_CONF=$CLI_PF_CONF
[ -z "$CLI_PROFILE" ] || PROFILE=$CLI_PROFILE
[ -z "$CLI_BLOCK_EXPIRE_SECONDS" ] || BLOCK_EXPIRE_SECONDS=$CLI_BLOCK_EXPIRE_SECONDS
[ -z "$CLI_RENDER_FILE" ] || RENDER_FILE=$CLI_RENDER_FILE
[ -z "$CLI_TORRC_PATHS" ] || TORRC_PATHS="$TORRC_PATHS $CLI_TORRC_PATHS"
[ -z "$CLI_TARGETS" ] || TARGETS="$TARGETS $CLI_TARGETS"
[ -z "$CLI_TRUST" ] || EXTRA_TRUST="$EXTRA_TRUST $CLI_TRUST"
[ -z "$CLI_SERVICES" ] || EXEMPT_SERVICES="$EXEMPT_SERVICES $CLI_SERVICES"
[ -z "$CLI_ENABLE_IPV4" ] || ENABLE_IPV4=$CLI_ENABLE_IPV4
[ -z "$CLI_ENABLE_IPV6" ] || ENABLE_IPV6=$CLI_ENABLE_IPV6

tor_ddos_apply_profile

TORRC_PATHS=$(tor_ddos_trim_words "$TORRC_PATHS")
TARGETS=$(tor_ddos_trim_words "$TARGETS")
EXTRA_TRUST=$(tor_ddos_trim_words "$EXTRA_TRUST")
EXEMPT_SERVICES=$(tor_ddos_trim_words "$EXEMPT_SERVICES")

tor_ddos_finalize_paths

case "$COMMAND" in
  enable)
    tor_ddos_enable
    ;;
  check)
    tor_ddos_check
    ;;
  apply)
    tor_ddos_apply
    ;;
  refresh)
    tor_ddos_refresh
    ;;
  expire)
    tor_ddos_expire
    ;;
  render)
    tor_ddos_render
    ;;
  status)
    tor_ddos_status
    ;;
  install-hook)
    tor_ddos_install_hook
    ;;
  install-cron)
    tor_ddos_install_cron
    ;;
  remove-cron)
    tor_ddos_remove_cron
    ;;
  disable)
    tor_ddos_disable
    ;;
esac
