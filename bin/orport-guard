#!/bin/sh

set -eu

PROGRAM_NAME=${0##*/}
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ROOT_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
PROGRAM_PATH=$SCRIPT_DIR/$PROGRAM_NAME
TOR_DDOS_LIB_DIR=$ROOT_DIR/lib

. "$ROOT_DIR/lib/pf.sh"
. "$ROOT_DIR/lib/cli.sh"

ORIGINAL_ARGV=$(tor_ddos_build_quoted_argv "$@")

usage() {
  cat <<EOF
Usage: $PROGRAM_NAME [options] <command>

Commands:
  enable     First install or full reconcile: install the PF hook if needed,
             reload pf.conf, then apply the managed anchor.
  check      Discover current targets in a temporary workspace, refresh trust
             data, and run PF syntax checks without loading live PF.
  apply      Reload the managed anchor only. The PF root hook must already be
             live.
  refresh    Refresh live trust tables only.
  expire     Expire live block-table entries older than the configured
             threshold.
  render     Discover current targets in a temporary workspace, refresh trust
             data, and print the generated anchor.
  status     Show the current live anchor state and cached metadata.
  install-hook
             Ensure the root pf.conf contains anchor "orport-guard".
             Advanced/manual path; enable already handles this.
  install-cron
             Install the managed cron block: expire every minute, refresh every
             6 hours.
  remove-cron
             Remove only the managed cron block for this tool.
  update     Download the latest standalone release artifact and replace the
             current script in place.
  disable    Unload the managed anchor and flush its tables. Leaves the PF
             hook and cron entries in place.

Options:
  -c, --config PATH           Use an alternate config file.
      --state-dir PATH        Override the state directory.
      --anchor NAME           Override the PF anchor name.
      --pf-conf PATH          Override the root PF config path.
      --profile NAME          Select a threshold profile (default or aggressive).
      --block-expire-seconds N
                              Expire block-table entries older than N seconds.
      --render-file PATH      Override the rendered anchor path.
      --torrc PATH            Add a torrc path for discovery. Repeatable.
      --target VALUE          Add an explicit target (IPv4:port or [IPv6]:port).
                              Repeatable. Explicit targets replace autodiscovery.
      --trust VALUE           Add an explicit trusted IP or network. Repeatable.
      --service VALUE         Add an exempt local service (IPv4:port or [IPv6]:port).
                              Repeatable.
      --ipv4-only             Restrict discovery and rendering to IPv4.
      --ipv6-only             Restrict discovery and rendering to IPv6.
  -h, --help                  Show this help text.

Config precedence:
  CLI flags override the config file, which overrides discovery defaults.

Option scoping:
  Options are command-scoped. Unsupported flags for a given subcommand are
  rejected instead of being silently ignored.
EOF
}

CONFIG_FILE=
COMMAND=
CLI_STATE_DIR=
CLI_ANCHOR=
CLI_PF_CONF=
CLI_PROFILE=
CLI_BLOCK_EXPIRE_SECONDS=
CLI_RENDER_FILE=
CLI_TORRC_PATHS=
CLI_TARGETS=
CLI_TRUST=
CLI_SERVICES=
CLI_ENABLE_IPV4=
CLI_ENABLE_IPV6=
CLI_FAMILY_MODE=
CLI_USED_OPTIONS=

while [ $# -gt 0 ]; do
  case "$1" in
    enable|check|apply|refresh|expire|render|status|install-hook|install-cron|remove-cron|update|disable)
      COMMAND=$1
      shift
      break
      ;;
    -c|--config)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CONFIG_FILE=$2
      tor_ddos_mark_option_used config
      shift 2
      ;;
    --state-dir)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_STATE_DIR=$2
      tor_ddos_mark_option_used state-dir
      shift 2
      ;;
    --anchor)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_ANCHOR=$2
      tor_ddos_mark_option_used anchor
      shift 2
      ;;
    --pf-conf)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_PF_CONF=$2
      tor_ddos_mark_option_used pf-conf
      shift 2
      ;;
    --profile)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_PROFILE=$2
      tor_ddos_mark_option_used profile
      shift 2
      ;;
    --block-expire-seconds)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_BLOCK_EXPIRE_SECONDS=$2
      tor_ddos_mark_option_used block-expire-seconds
      shift 2
      ;;
    --render-file)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_RENDER_FILE=$2
      tor_ddos_mark_option_used render-file
      shift 2
      ;;
    --torrc)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_TORRC_PATHS="$CLI_TORRC_PATHS $2"
      tor_ddos_mark_option_used torrc
      shift 2
      ;;
    --target)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_TARGETS="$CLI_TARGETS $2"
      tor_ddos_mark_option_used target
      shift 2
      ;;
    --trust)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_TRUST="$CLI_TRUST $2"
      tor_ddos_mark_option_used trust
      shift 2
      ;;
    --service)
      [ $# -ge 2 ] || tor_ddos_die "missing value for $1"
      CLI_SERVICES="$CLI_SERVICES $2"
      tor_ddos_mark_option_used service
      shift 2
      ;;
    --ipv4-only)
      [ -z "$CLI_FAMILY_MODE" ] || tor_ddos_die "cannot combine --ipv4-only with --ipv6-only"
      CLI_FAMILY_MODE=ipv4-only
      CLI_ENABLE_IPV4=1
      CLI_ENABLE_IPV6=0
      tor_ddos_mark_option_used ipv4-only
      shift
      ;;
    --ipv6-only)
      [ -z "$CLI_FAMILY_MODE" ] || tor_ddos_die "cannot combine --ipv6-only with --ipv4-only"
      CLI_FAMILY_MODE=ipv6-only
      CLI_ENABLE_IPV4=0
      CLI_ENABLE_IPV6=1
      tor_ddos_mark_option_used ipv6-only
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      tor_ddos_die "unknown argument: $1"
      ;;
  esac
done

[ -n "$COMMAND" ] || {
  usage >&2
  exit 2
}

[ $# -eq 0 ] || tor_ddos_die "unexpected trailing argument after $COMMAND: $1"

tor_ddos_validate_command_options "$COMMAND"

tor_ddos_set_defaults "$ROOT_DIR"

if [ -n "$CONFIG_FILE" ]; then
  [ -f "$CONFIG_FILE" ] || tor_ddos_die "config file not found: $CONFIG_FILE"
  tor_ddos_load_config "$CONFIG_FILE"
else
  tor_ddos_load_config "$CONFIG_FILE_DEFAULT"
fi

[ -z "$CLI_STATE_DIR" ] || STATE_DIR=$CLI_STATE_DIR
[ -z "$CLI_ANCHOR" ] || PF_ANCHOR=$CLI_ANCHOR
[ -z "$CLI_PF_CONF" ] || PF_CONF=$CLI_PF_CONF
[ -z "$CLI_PROFILE" ] || PROFILE=$CLI_PROFILE
[ -z "$CLI_BLOCK_EXPIRE_SECONDS" ] || BLOCK_EXPIRE_SECONDS=$CLI_BLOCK_EXPIRE_SECONDS
[ -z "$CLI_RENDER_FILE" ] || RENDER_FILE=$CLI_RENDER_FILE
[ -z "$CLI_TORRC_PATHS" ] || TORRC_PATHS="$TORRC_PATHS $CLI_TORRC_PATHS"
[ -z "$CLI_TARGETS" ] || TARGETS="$TARGETS $CLI_TARGETS"
[ -z "$CLI_TRUST" ] || EXTRA_TRUST="$EXTRA_TRUST $CLI_TRUST"
[ -z "$CLI_SERVICES" ] || EXEMPT_SERVICES="$EXEMPT_SERVICES $CLI_SERVICES"
[ -z "$CLI_ENABLE_IPV4" ] || ENABLE_IPV4=$CLI_ENABLE_IPV4
[ -z "$CLI_ENABLE_IPV6" ] || ENABLE_IPV6=$CLI_ENABLE_IPV6

tor_ddos_apply_profile

TORRC_PATHS=$(tor_ddos_trim_words "$TORRC_PATHS")
TARGETS=$(tor_ddos_trim_words "$TARGETS")
EXTRA_TRUST=$(tor_ddos_trim_words "$EXTRA_TRUST")
EXEMPT_SERVICES=$(tor_ddos_trim_words "$EXEMPT_SERVICES")

tor_ddos_finalize_paths
tor_ddos_reexec_with_privileges_if_needed "$COMMAND" "$ORIGINAL_ARGV"

case "$COMMAND" in
  enable)
    tor_ddos_enable
    ;;
  check)
    tor_ddos_check
    ;;
  apply)
    tor_ddos_apply
    ;;
  refresh)
    tor_ddos_refresh
    ;;
  expire)
    tor_ddos_expire
    ;;
  render)
    tor_ddos_render
    ;;
  status)
    tor_ddos_status
    ;;
  install-hook)
    tor_ddos_install_hook
    ;;
  install-cron)
    tor_ddos_install_cron
    ;;
  remove-cron)
    tor_ddos_remove_cron
    ;;
  update)
    tor_ddos_update "$ORIGINAL_ARGV"
    ;;
  disable)
    tor_ddos_disable
    ;;
esac
